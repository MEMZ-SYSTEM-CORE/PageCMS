---
import Header from '../components/Header.svelte';
import BackToTop from '../components/BackToTop.svelte';
import ScrollProgress from '../components/ScrollProgress.svelte';
import ImageLightbox from '../components/ImageLightbox.svelte';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
}

const {
  title = 'MEMZ-SYSTEM-CORE',
  description = 'MEMZ-SYSTEM-CORE 的博客',
  image: ogImage,
  canonicalURL,
  type = 'website',
  publishedTime,
  tags = [],
} = Astro.props;

// Read site settings
const settingsModules = import.meta.glob('../content/settings/*.md', { eager: true });
const settingsFile = Object.values(settingsModules)[0] as any;
const siteName = settingsFile?.frontmatter?.siteName || 'MEMZ-SYSTEM-CORE';
const footerText = settingsFile?.frontmatter?.footerText || '基于 Astro · PagesCMS';
const defaultOGImage = settingsFile?.frontmatter?.ogImage || '/favicon.svg';
const seoDescription = settingsFile?.frontmatter?.seoDescription || siteName + ' 的博客';

const finalDescription = description || seoDescription;

const finalOGImage = ogImage || defaultOGImage;
const absoluteURL = Astro.url.origin;
const pageURL = canonicalURL || Astro.url.href;
const fullImageURL = finalOGImage.startsWith('http') ? finalOGImage : `${absoluteURL}${finalOGImage}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />

    <!-- SEO Meta -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={pageURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={finalDescription} />
    <meta name="keywords" content={tags.length > 0 ? tags.join(', ') : '博客, MEMZ-SYSTEM-CORE, 技术博客'} />

    <!-- Open Graph -->
    <meta property="og:title" content={title + ' — ' + siteName} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={pageURL} />
    <meta property="og:image" content={fullImageURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_CN" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title + ' — ' + siteName} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={fullImageURL} />

    <title>{title} — {siteName}</title>

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={siteName + ' RSS Feed'} href="/rss.xml" />

    <!-- Dark theme flash prevention -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
          document.querySelector('meta[name="theme-color"]').content = '#0a0a0a';
        }
      })();
    </script>

    <!-- Preconnect to external services -->
    <link rel="preconnect" href="https://space.bilibili.com" />
  </head>
  <body class="bg-background text-foreground flex flex-col min-h-dvh antialiased">
    <ScrollProgress />
    <Header siteName={siteName} />

    <main class="flex-1 min-h-0">
      <div class="container mx-auto max-w-4xl px-4 py-12">
        <slot />
      </div>
    </main>

    <footer class="mt-8 border-t pt-6 pb-8">
      <div class="container mx-auto flex flex-col items-center gap-2 text-sm text-muted-foreground max-w-4xl px-4">
        <nav class="flex items-center gap-4" aria-label="页脚导航">
          <a href="/" class="hover:text-foreground transition-colors">首页</a>
          <span class="text-muted-foreground/40">·</span>
          <a href="/about" class="hover:text-foreground transition-colors">关于</a>
          <span class="text-muted-foreground/40">·</span>
          <a href="/rss.xml" class="hover:text-foreground transition-colors inline-flex items-center gap-1">
            <svg viewBox="0 0 24 24" fill="currentColor" class="!size-3.5"><circle cx="5" cy="19" r="2"/><path d="M5 11a8 8 0 0 1 8 8h2a10 10 0 0 0-10-10v2z"/><path d="M5 5a14 14 0 0 1 14 14h2a16 16 0 0 0-16-16v2z"/></svg>
            RSS
          </a>
          <span class="text-muted-foreground/40">·</span>
          <a href="https://space.bilibili.com/3494379408853453" target="_blank" class="hover:text-foreground inline-flex items-center gap-1 transition-colors">
            <svg viewBox="0 0 24 24" fill="currentColor" class="!size-3.5"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.92.453.267.302.4.622.4.96 0 .338-.133.658-.4.96l-1.147 1.12v-.16zm-8.546 5.707a.7.7 0 0 0-.693.693v4.267c0 .373.32.693.693.693.373 0 .693-.32.693-.693v-4.267a.7.7 0 0 0-.693-.693zm5.333 0a.7.7 0 0 0-.693.693v4.267c0 .373.32.693.693.693.373 0 .693-.32.693-.693v-4.267a.7.7 0 0 0-.693-.693z"/></svg>
            B站
          </a>
        </nav>
        <p class="text-xs text-muted-foreground/60">© {new Date().getFullYear()} {siteName} · {footerText}</p>
      </div>
    </footer>

    <BackToTop />
    <ImageLightbox />
  </body>
</html>
