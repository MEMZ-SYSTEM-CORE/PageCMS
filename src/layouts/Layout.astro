---
import Header from '../components/Header.svelte';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'PageCMS', description = '一个由 PagesCMS 管理的 Astro 静态站点' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — PageCMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/globals.css" />
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <Header />
    <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-12">
      <slot />
    </main>
    <footer class="border-border/40 text-muted-foreground mx-auto flex w-full max-w-5xl items-center justify-center border-t px-4 py-6 text-xs sm:px-6">
      由 <a href="https://astro.build" target="_blank" class="hover:text-foreground underline underline-offset-2 transition-colors">Astro</a> 构建 · 内容通过 <a href="https://pagescms.org" target="_blank" class="hover:text-foreground underline underline-offset-2 transition-colors">Pages CMS</a> 管理
    </footer>
  </body>
</html>
