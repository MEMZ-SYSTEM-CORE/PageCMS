---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const tracks = await getCollection('music');
const sorted = tracks
  .map((t) => ({
    title: t.data.title,
    artist: t.data.artist,
    file: t.data.file,
    cover: t.data.cover,
    order: t.data.order ?? 99,
  }))
  .sort((a, b) => a.order - b.order);
---

<Layout title="音乐" description="MEMZ-SYSTEM-CORE 的音乐">
  <article class="animate-fade-up">
    <div class="flex items-center gap-2 text-sm text-muted-foreground mb-2">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="!size-4"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      <span>音乐</span>
    </div>
    <h1 class="mb-2 text-4xl font-bold">音乐</h1>
    <p class="text-sm text-muted-foreground mb-8">{sorted.length} 首曲目</p>

    {sorted.length > 0 ? (
      <div class="space-y-2">
        {sorted.map((track, i) => (
          <div
            class="music-track ring-foreground/10 bg-card text-card-foreground flex items-center gap-4 rounded-2xl ring-1 px-5 py-4 group transition-all hover:shadow-lg cursor-pointer"
            data-index={i}
            data-file={track.file}
            data-title={track.title}
            data-artist={track.artist}
            data-cover={track.cover || ''}
          >
            <div class="size-12 shrink-0 rounded-lg bg-muted flex items-center justify-center overflow-hidden">
              {track.cover ? (
                <img src={track.cover} alt="" class="size-full object-cover" />
              ) : (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="!size-5 text-muted-foreground/40"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium">{track.title}</div>
              <div class="text-xs text-muted-foreground">{track.artist}</div>
            </div>
            <button
              class="play-btn shrink-0 flex size-9 items-center justify-center rounded-full bg-foreground/10 text-foreground opacity-0 group-hover:opacity-100 transition-all hover:bg-foreground hover:text-background"
              aria-label="播放 {track.title}"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="!size-4 ml-0.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </button>
          </div>
        ))}
      </div>
    ) : (
      <div class="rounded-2xl border border-dashed border-border/40 p-16 text-center text-sm text-muted-foreground">
        还没有音乐 — 去 app.pagescms.org 添加
      </div>
    )}
  </article>

  <script>
    (function() {
      var list = document.querySelectorAll('.music-track');
      if (!list.length) return;

      list.forEach(function(el) {
        el.addEventListener('click', function() {
          var idx = parseInt(el.getAttribute('data-index') || '0');
          var file = el.getAttribute('data-file') || '';
          var title = el.getAttribute('data-title') || '';
          var artist = el.getAttribute('data-artist') || '';
          var cover = el.getAttribute('data-cover') || '';
          var w = window.__musicPlayer;
          if (w) {
            w.playTrack([{ title: title, artist: artist, file: file, cover: cover }], 0);
          }
        });
      });
    })();
  </script>
</Layout>
