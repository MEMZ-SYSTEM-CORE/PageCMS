---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Badge } from '../../lib/components/ui/badge/index.js';
import { Separator } from '../../lib/components/ui/separator/index.js';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/i, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, pubDate, description, tags } = post.data;

function resolveTag(t) {
  return typeof t === 'string' ? t : t?.tag ?? '';
}

const readingTime = Math.max(1, Math.ceil((description?.length ?? 100) / 300));
const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Layout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <!-- Back link -->
    <a
      href="/"
      class="text-muted-foreground hover:text-foreground mb-8 inline-flex items-center gap-1 text-xs font-medium transition-colors"
    >
      <span aria-hidden="true" class="text-base leading-none">←</span>
      返回首页
    </a>

    <!-- Header -->
    <header class="mb-10 space-y-4">
      <div class="text-muted-foreground flex items-center gap-3 text-xs">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        <Separator orientation="vertical" class="h-3" />
        <span>{readingTime} 分钟阅读</span>
      </div>

      <h1 class="font-heading text-foreground text-3xl font-bold tracking-tight sm:text-4xl">
        {title}
      </h1>

      {description && (
        <p class="text-muted-foreground text-sm leading-relaxed sm:text-base">{description}</p>
      )}

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => <Badge variant="secondary">{resolveTag(tag)}</Badge>)}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose-content">
      <Content />
    </div>

    <!-- Bottom separator -->
    <Separator class="my-12" />

    <!-- Back to home -->
    <div class="text-center">
      <a
        href="/"
        class="hover:text-primary text-muted-foreground inline-flex items-center gap-1.5 text-xs font-medium transition-colors"
      >
        <span aria-hidden="true" class="text-base leading-none">←</span>
        返回所有文章
      </a>
    </div>
  </article>
</Layout>

<style define:vars={{}}>
  .prose-content :global(h2) {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.45rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-foreground);
    letter-spacing: -0.01em;
  }
  .prose-content :global(h3) {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--color-foreground);
  }
  .prose-content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    font-size: 0.95rem;
  }
  .prose-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 0.5px;
  }
  .prose-content :global(a:hover) {
    text-decoration-thickness: 1.5px;
  }
  .prose-content :global(ul), .prose-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-content :global(li) {
    margin-bottom: 0.35rem;
    line-height: 1.75;
    font-size: 0.95rem;
  }
  .prose-content :global(code) {
    background: var(--color-muted);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.85em;
    font-weight: 500;
  }
  .prose-content :global(pre) {
    background: oklch(0.18 0.02 var(--hue, 240));
    color: oklch(0.88 0.01 var(--hue, 240));
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-weight: 400;
  }
  .prose-content :global(blockquote) {
    border-left: 2.5px solid var(--color-primary);
    padding-left: 1rem;
    color: var(--color-muted-foreground);
    font-style: italic;
    margin: 1.5rem 0;
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .prose-content :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 2rem 0;
    box-shadow: 0 1px 3px oklch(0 0 0 / 0.05);
  }
  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
    opacity: 0.6;
  }
  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }
  .prose-content :global(th), .prose-content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.85rem;
    text-align: left;
  }
  .prose-content :global(th) {
    background: var(--color-muted);
    font-weight: 600;
  }
  .prose-content :global(strong) {
    font-weight: 600;
  }
</style>
