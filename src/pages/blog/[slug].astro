---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/i, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, pubDate, description, image, tags } = post.data;

function resolveTag(t) {
  return typeof t === 'string' ? t : t?.tag ?? '';
}

const resolvedTags = (tags ?? [])
  .map((t) => (typeof t === 'string' ? t : t?.tag ?? ''))
  .filter(Boolean);

const readingTime = Math.max(1, Math.ceil((description?.length ?? 100) / 400));
const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const wordCount = Math.ceil((description?.length ?? 0) * 1.5 + 100);
const isoDate = pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString();
const slug = post.id.replace(/\.md$/i, '');
const canonicalURL = new URL(`/blog/${slug}/`, Astro.url.origin).href;

// Build structured data
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: isoDate,
  author: {
    '@type': 'Person',
    name: 'MEMZ-SYSTEM-CORE',
  },
  publisher: {
    '@type': 'Organization',
    name: 'MEMZ-SYSTEM-CORE',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.url.origin).href,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
  wordCount: wordCount,
  ...(image ? { image: image.startsWith('http') ? image : new URL(image, Astro.url.origin).href } : {}),
};

if (resolvedTags.length > 0) {
  blogPosting.keywords = resolvedTags.join(', ');
}
---
<Layout
  title={title}
  description={description || '阅读文章'}
  image={image}
  canonicalURL={canonicalURL}
  type="article"
  publishedTime={isoDate}
  tags={resolvedTags}
>
  <!-- JSON-LD Structured Data -->
  <script is:inline set:html={JSON.stringify(blogPosting, null, 2)} type="application/ld+json" />

  <article class="animate-fade-up">
    <nav aria-label="面包屑导航">
      <a href="/" class="inline-flex items-center gap-1 hover:text-foreground transition-colors text-sm text-muted-foreground mb-8">
        ← 返回文章列表
      </a>
    </nav>

    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-muted-foreground mb-1">
        <time datetime={isoDate}>{dateStr}</time>
        <span class="text-muted-foreground/40">·</span>
        <span>{readingTime} 分钟阅读</span>
        <span class="text-muted-foreground/40">·</span>
        <span>{wordCount} 字</span>
      </div>

      <h1 class="mb-4 text-4xl font-bold">{title}</h1>

      {description && (
        <p class="text-sm text-muted-foreground">{description}</p>
      )}

      {image && (
        <div class="mt-6 -mx-4 sm:-mx-0">
          <img src={image} alt={title} class="w-full rounded-xl object-cover max-h-96" loading="lazy" decoding="async" />
        </div>
      )}

      {resolvedTags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {resolvedTags.map((tag) => (
            <span class="inline-flex items-center rounded-4xl border border-transparent bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-medium">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose" id="prose-content">
      <Content />
    </div>

    <script>
      (function() {
        var prose = document.getElementById('prose-content');
        if (!prose) return;

        var avRe = /\.(mp4|webm|ogg|mov|avi|mkv|mp3|wav|flac|aac|m4a|wma)(?:$|[?#])/i;
        var videoRe = /\.(mp4|webm|ogg|mov|avi|mkv)/i;
        var fileRe = /\.(exe|zip|7z|rar|tar|gz|pdf|doc|docx|xls|xlsx|ppt|pptx|apk|deb|rpm|iso|dmg|msi)(?:$|[?#])/i;
        var allRe = /\.(mp4|webm|ogg|mov|avi|mkv|mp3|wav|flac|aac|m4a|wma|exe|zip|7z|rar|tar|gz|pdf|doc|docx|xls|xlsx|ppt|pptx|apk|deb|rpm|iso|dmg|msi)(?:$|[?#])/i;

        function makePlayer(src) {
          var ext = src.split('.').pop().split(/[?#]/)[0].toLowerCase();
          var w = document.createElement('div');
          w.className = 'my-6';
          w.setAttribute('data-media', '');

          if (videoRe.test(src)) {
            var v = document.createElement('video');
            v.src = src; v.controls = true; v.playsInline = true; v.preload = 'metadata';
            v.className = 'w-full max-h-[70vh] rounded-2xl bg-black ring-1 ring-foreground/10';
            w.appendChild(v);
            return w;
          }

          if (avRe.test(src) && !fileRe.test(src)) {
            // Audio
            var name = src.split('/').pop() || 'audio';
            var c = document.createElement('div');
            c.className = 'ring-foreground/10 bg-card text-card-foreground flex items-center gap-4 rounded-2xl ring-1 p-5';
            c.innerHTML = '<div class="flex size-12 shrink-0 items-center justify-center rounded-full bg-muted"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="!size-6 text-muted-foreground"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div><div class="flex-1 min-w-0"><div class="text-xs font-medium text-muted-foreground truncate mb-2">' + name + '</div><audio src="' + src + '" controls preload="none" class="w-full h-10"></audio></div>';
            w.appendChild(c);
            return w;
          }

          // File download card
          var fileName = src.split('/').pop() || 'file';
          var displayName = fileName.length > 40 ? fileName.slice(0, 37) + '...' : fileName;
          var icon = getFileIcon(ext);
          var card = document.createElement('div');
          card.className = 'group relative overflow-hidden rounded-2xl ring-1 ring-foreground/10 bg-gradient-to-br from-card to-muted/30 transition-all duration-300 hover:ring-foreground/20 hover:shadow-md';
          card.innerHTML = '<div class="flex items-center gap-4 p-5"><div class="flex size-14 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-accent/5 to-accent/10 text-2xl shadow-sm ring-1 ring-foreground/5">' + icon + '</div><div class="flex-1 min-w-0"><div class="flex items-center gap-2"><span class="inline-flex items-center rounded-md bg-accent/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-accent/70">' + ext.toUpperCase() + '</span></div><div class="mt-1.5 text-sm font-medium truncate text-foreground/90">' + displayName + '</div><div class="mt-0.5 flex items-center gap-3 text-xs text-muted-foreground"><span>📎 文件下载</span></div></div><a href="' + src + '" target="_blank" rel="noopener noreferrer" class="shrink-0 inline-flex items-center gap-1.5 rounded-xl bg-accent px-4 py-2.5 text-xs font-semibold text-accent-foreground shadow-sm transition-all duration-200 hover:opacity-90 hover:shadow-md active:scale-95 no-underline"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="!size-3.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>下载</a></div>';
          w.appendChild(card);
          return w;
        }

        function getFileIcon(ext) {
          if (/zip|7z|rar|tar|gz/.test(ext)) return '📦';
          if (/pdf|doc|docx|xls|xlsx|ppt|pptx/.test(ext)) return '📄';
          if (/exe|msi|apk|deb|rpm|dmg|iso/.test(ext)) return '⚙️';
          return '📎';
        }

        // Walk text nodes for bare media/file URLs
        var iter = document.createTreeWalker(prose, NodeFilter.SHOW_TEXT, null, false);
        var todo = [];
        while (iter.nextNode()) {
          var n = iter.currentNode;
          var txt = n.textContent;
          if (!txt) continue;
          var p = n.parentNode;
          if (p.tagName === 'A') continue;
          if (p.closest && p.closest('[data-media]')) continue;
          var urlMatch = txt.match(/(https?:\/\/\S+?|\/\S+?)\.(?:mp4|webm|ogg|mov|avi|mkv|mp3|wav|flac|aac|m4a|wma|exe|zip|7z|rar|tar|gz|pdf|doc|docx|xls|xlsx|ppt|pptx|apk|deb|rpm|iso|dmg|msi)(?:[?#]\S*)?/i);
          if (!urlMatch) continue;
          var url = urlMatch[0];
          var idx = txt.indexOf(url);
          var before = txt.slice(0, idx);
          var after = txt.slice(idx + url.length);
          var frag = document.createDocumentFragment();
          if (before) frag.appendChild(document.createTextNode(before));
          frag.appendChild(makePlayer(url));
          if (after) frag.appendChild(document.createTextNode(after));
          todo.push({ node: n, frag: frag });
        }
        todo.forEach(function(t) { t.node.parentNode.replaceChild(t.frag, t.node); });

        // Handle <a> links to media/file URLs
        prose.querySelectorAll('a').forEach(function(a) {
          if (a.href && allRe.test(a.href) && !a.hasAttribute('data-skip-media')) {
            a.parentNode.replaceChild(makePlayer(a.href), a);
          }
        });
      })();
    </script>

    <nav class="mt-16 border-t pt-6" aria-label="文章导航">
      <a href="/" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors">
        ← 返回所有文章
      </a>
    </nav>
  </article>
</Layout>
