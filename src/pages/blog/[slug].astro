---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Badge } from '../../lib/components/ui/badge/index.js';
import { Separator } from '../../lib/components/ui/separator/index.js';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/i, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, pubDate, description, tags } = post.data;

function resolveTag(t) {
  return typeof t === 'string' ? t : t?.tag ?? '';
}

const readingTime = Math.max(1, Math.ceil((description?.length ?? 100) / 400));
const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Layout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <a href="/" class="text-muted-foreground hover:text-foreground mb-8 inline-flex items-center gap-1 text-xs transition-colors">← 返回</a>

    <header class="mb-10 space-y-4">
      <div class="flex items-center gap-2 text-xs text-muted-foreground">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} 分钟阅读</span>
      </div>

      <h1 class="text-3xl font-bold tracking-tight leading-[1.15] sm:text-4xl">{title}</h1>

      {description && <p class="text-muted-foreground text-sm leading-relaxed">{description}</p>}

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => <Badge variant="secondary">{resolveTag(tag)}</Badge>)}
        </div>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>

    <Separator class="my-16" />
    <a href="/" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-1 text-xs transition-colors">← 返回所有文章</a>
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.8;
    font-size: 0.95rem;
  }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1rem; }
  .prose :global(li) { margin-bottom: 0.25rem; line-height: 1.75; font-size: 0.95rem; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(code) {
    background: var(--color-muted);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.85em;
  }
  .prose :global(pre) {
    background: oklch(0.15 0 0);
    color: oklch(0.85 0 0);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 0.875rem;
  }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(blockquote) {
    border-left: 2px solid var(--color-foreground);
    padding-left: 1rem;
    color: var(--color-muted-foreground);
    margin: 1rem 0;
  }
  .prose :global(img) { max-width: 100%; border-radius: 4px; margin: 1.5rem 0; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }
</style>
