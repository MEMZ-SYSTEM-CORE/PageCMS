---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/i, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, pubDate, description, image, tags } = post.data;

function resolveTag(t) {
  return typeof t === 'string' ? t : t?.tag ?? '';
}

const readingTime = Math.max(1, Math.ceil((description?.length ?? 100) / 400));
const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const wordCount = Math.ceil((description?.length ?? 0) * 1.5 + 100);
---

<Layout title={title} description={description}>
  <article class="animate-fade-up">
    <!-- Back link -->
    <a href="/" class="inline-flex items-center gap-1 hover:text-foreground transition-colors text-sm text-muted-foreground mb-8">
      ← 返回文章列表
    </a>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-muted-foreground mb-1">
        <span>{dateStr}</span>
        <span class="text-muted-foreground/40">·</span>
        <span>{readingTime} 分钟阅读</span>
        <span class="text-muted-foreground/40">·</span>
        <span>{wordCount} 字</span>
      </div>

      <h1 class="mb-4 text-4xl font-bold">{title}</h1>

      {description && (
        <p class="text-sm text-muted-foreground">{description}</p>
      )}

      {image && (
        <div class="mt-6 -mx-4 sm:-mx-0">
          <img
            src={image}
            alt={title}
            class="w-full rounded-xl object-cover max-h-96"
          />
        </div>
      )}

      {tags && tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="inline-flex items-center rounded-4xl border border-transparent bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-medium">{resolveTag(tag)}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose" id="prose-content">
      <Content />
    </div>

    <!-- Media embed script: converts media links in content to inline players -->
    <script>
      (function() {
        var prose = document.getElementById('prose-content');
        if (!prose) return;
        var links = prose.querySelectorAll('a');
        links.forEach(function(a) {
          var href = a.href || '';
          var text = a.textContent.trim();
          // Only transform if link text matches the URL (plain link, not linked phrase)
          if (href !== text && !text.startsWith('http')) return;
          var isVideo = href.match(/\.(mp4|webm|ogg|mov)(\?|$)/i);
          var isAudio = href.match(/\.(mp3|wav|ogg|flac|aac|m4a)(\?|$)/i);
          if (!isVideo && !isAudio) return;

          var wrapper = document.createElement('div');
          wrapper.className = 'my-6';

          if (isVideo) {
            var video = document.createElement('video');
            video.src = href;
            video.controls = true;
            video.playsInline = true;
            video.preload = 'metadata';
            video.className = 'w-full max-h-[70vh] rounded-2xl bg-black ring-1 ring-foreground/10';
            wrapper.appendChild(video);
          } else {
            var name = href.split('/').pop() || '音频';
            var inner = document.createElement('div');
            inner.className = 'ring-foreground/10 bg-card text-card-foreground flex items-center gap-4 rounded-2xl ring-1 p-5';
            inner.innerHTML = '<div class="flex size-12 shrink-0 items-center justify-center rounded-full bg-muted"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="!size-6 text-muted-foreground"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div><div class="flex-1 min-w-0"><div class="text-xs font-medium text-muted-foreground truncate mb-2">' + name + '</div><audio src="' + href + '" controls preload="none" class="w-full h-10"></audio></div>';
            wrapper.appendChild(inner);
          }

          a.parentNode.replaceChild(wrapper, a);
        });
      })();
    </script>

    <!-- Footer -->
    <div class="mt-16 border-t pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
      >
        ← 返回所有文章
      </a>
    </div>
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose :global(h3) { font-size: 1.15rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; }
  .prose :global(p) { margin-bottom: 1.25rem; line-height: 1.85; font-size: 0.95rem; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose :global(li) { margin-bottom: 0.35rem; line-height: 1.85; font-size: 0.95rem; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(code) { background: var(--color-muted); padding: 0.15rem 0.45rem; border-radius: 3px; font-size: 0.85em; font-weight: 500; }
  .prose :global(pre) { background: oklch(0.15 0 0); color: oklch(0.85 0 0); padding: 1.25rem; border-radius: 12px; overflow-x: auto; margin: 1.5rem 0; font-size: 0.875rem; line-height: 1.6; }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(blockquote) { border-left: 2px solid var(--color-foreground); padding-left: 1rem; color: var(--color-muted-foreground); margin: 1.5rem 0; line-height: 1.75; }
  .prose :global(video) { max-width: 100%; border-radius: 12px; margin: 1.5rem 0; cursor: pointer; display: block; }
  .prose :global(audio) { max-width: 100%; margin: 1.5rem 0; display: block; }
  .prose :global(img) { max-width: 100%; border-radius: 8px; margin: 2rem 0; cursor: pointer; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.875rem; }
  .prose :global(th) { background: var(--color-muted); font-weight: 600; text-align: left; }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--color-border); padding: 0.6rem 0.85rem; }
</style>
