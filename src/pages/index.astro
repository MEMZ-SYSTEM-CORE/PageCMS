---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.svelte';
import PostCard from '../components/PostCard.svelte';
import TagCloud from '../components/TagCloud.svelte';
import ToolsWidget from '../components/ToolsWidget.svelte';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const latestPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);

const allTags = [
  ...new Set(
    posts
      .flatMap((p) => p.data.tags ?? [])
      .map((t) => (typeof t === 'string' ? t : t?.tag ?? ''))
      .filter(Boolean),
  ),
];

// Read site settings from markdown file
const settingsModules = import.meta.glob('../content/settings/*.md', { eager: true });
const settingsFile = Object.values(settingsModules)[0] as any;
const siteName = settingsFile?.frontmatter?.siteName || 'MEMZ-SYSTEM-CORE';
const tagline = settingsFile?.frontmatter?.tagline || '分享技术、想法和经验';
const footerText = settingsFile?.frontmatter?.footerText || '基于 Astro · PagesCMS';
---

<Layout title={siteName} description={siteName + ' 的博客'}>
  <Hero siteName={siteName} tagline={tagline} footerText={footerText} postCount={posts.length} />

  <!-- Widgets -->
  <div class="animate-fade-up">
    <ToolsWidget postCount={posts.length} tagCount={allTags.length} />
  </div>

  <!-- Posts -->
  {posts.length > 0 && (
    <section id="posts" class="space-y-5 pb-12 mt-10">
      <div class="animate-fade-up flex items-center gap-3">
        <h2 class="text-xs font-medium uppercase text-muted-foreground tracking-wider">文章</h2>
        <div class="h-px flex-1 bg-border/60" />
        <span class="text-xs text-muted-foreground/60">{posts.length} 篇</span>
      </div>

      <div class="space-y-4">
        {latestPosts.map((post, i) => {
          const rawTags = post.data.tags;
          const tags = rawTags?.map((t) => (typeof t === 'string' ? t : t?.tag ?? '')).filter(Boolean) ?? [];
          return (
            <PostCard
              index={i}
              post={{
                slug: post.id.replace(/\.md$/i, ''),
                title: post.data.title,
                pubDate: post.data.pubDate.toISOString(),
                description: post.data.description,
                image: post.data.image,
                tags,
              }}
            />
          );
        })}
      </div>
    </section>
  )}

  {posts.length === 0 && (
    <section class="animate-fade-up rounded-2xl border border-dashed border-border/40 p-16 text-center">
      <p class="text-sm text-muted-foreground">还没有文章</p>
    </section>
  )}

  {allTags.length > 0 && (
    <section class="animate-fade-up space-y-4 pb-12 mt-6 border-t pt-6">
      <div class="flex items-center gap-3">
        <h2 class="text-xs font-medium uppercase text-muted-foreground tracking-wider">标签</h2>
        <div class="h-px flex-1 bg-border/60" />
        <span class="text-xs text-muted-foreground/60">{allTags.length} 个</span>
      </div>
      <TagCloud tags={allTags} />
    </section>
  )}
</Layout>
