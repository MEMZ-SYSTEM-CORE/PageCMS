---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.svelte';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const latestPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
const pages = await getCollection('pages');
---

<Layout title="首页" description="一个由 PagesCMS 管理的 Astro 静态站点">
  <section class="mb-10 space-y-2">
    <h1 class="font-heading text-foreground text-3xl font-bold tracking-tight sm:text-4xl">
      欢迎来到 PageCMS 🎉
    </h1>
    <p class="text-muted-foreground max-w-2xl text-sm sm:text-base">
      这是一个基于 <strong>Astro</strong> 构建、通过 <strong>PagesCMS</strong> 管理内容的静态站点模板。
    </p>
    <p class="text-muted-foreground text-xs">
      {posts.length} 篇文章 · {pages.length} 个页面
    </p>
  </section>

  <section class="space-y-4">
    <h2 class="font-heading text-foreground text-xl font-semibold">最新文章</h2>
    {posts.length > 0 ? (
      <div class="space-y-3">
        {latestPosts.map((post) => (
          <PostCard
            post={{
              slug: post.id.replace(/\.md$/i, ''),
              title: post.data.title,
              pubDate: post.data.pubDate.toISOString(),
              description: post.data.description,
              tags: post.data.tags?.map((t) => (typeof t === 'string' ? { tag: t } : t)) ?? [],
            }}
          />
        ))}
      </div>
    ) : (
      <p class="text-muted-foreground text-sm">
        还没有文章，前往
        <a href="https://app.pagescms.org" target="_blank" class="text-primary hover:underline">
          app.pagescms.org
        </a>
        开始编辑吧！
      </p>
    )}
  </section>
</Layout>
