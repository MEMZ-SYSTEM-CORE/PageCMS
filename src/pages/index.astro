---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.svelte';
import PostCard from '../components/PostCard.svelte';
import TagCloud from '../components/TagCloud.svelte';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const latestPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
const pages = await getCollection('pages');

const allTags = [
  ...new Set(
    posts
      .flatMap((p) => p.data.tags ?? [])
      .map((t) => (typeof t === 'string' ? t : t?.tag ?? ''))
      .filter(Boolean),
  ),
];
---

<Layout title="首页" description="MEMZ-SYSTEM-CORE 的博客">
  <Hero postCount={posts.length} />

  {posts.length > 0 && (
    <section id="posts" class="space-y-6 pb-16">
      {latestPosts.map((post, i) => {
        const rawTags = post.data.tags;
        const tags = rawTags?.map((t) => (typeof t === 'string' ? t : t?.tag ?? '')).filter(Boolean) ?? [];
        return (
          <PostCard
            index={i}
            post={{
              slug: post.id.replace(/\.md$/i, ''),
              title: post.data.title,
              pubDate: post.data.pubDate.toISOString(),
              description: post.data.description,
              image: post.data.image,
              tags,
            }}
          />
        );
      })}
    </section>
  )}

  {posts.length === 0 && (
    <section class="animate-fade-up rounded-xl border border-dashed border-border/40 p-16 text-center">
      <p class="text-sm text-muted-foreground">还没有文章</p>
    </section>
  )}

  {allTags.length > 0 && (
    <section class="animate-fade-up space-y-4 pb-16 mt-8 border-t pt-6">
      <div class="flex items-center gap-4">
        <h2 class="text-xs font-medium uppercase text-muted-foreground tracking-wider">标签</h2>
        <div class="h-px flex-1 bg-border" />
      </div>
      <TagCloud tags={allTags} />
    </section>
  )}
</Layout>
