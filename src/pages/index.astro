---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.svelte';
import PostCard from '../components/PostCard.svelte';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const latestPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
const pages = await getCollection('pages');
---

<Layout title="首页" description="一个由 PagesCMS 管理的 Astro 静态站点">
  <Hero postCount={posts.length} pageCount={pages.length} />

  {posts.length > 0 && (
    <section id="posts" class="scroll-mt-20 space-y-8 pb-24">
      <div class="animate-fade-up flex items-center gap-4">
        <h2 class="font-heading text-xl font-semibold tracking-tight text-foreground sm:text-2xl">最新文章</h2>
        <div class="h-px flex-1 bg-border" />
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        {latestPosts.map((post, i) => {
          const rawTags = post.data.tags;
          const tags = rawTags?.map((t) => (typeof t === 'string' ? t : t?.tag ?? '')).filter(Boolean) ?? [];
          return (
            <PostCard
              index={i}
              post={{
                slug: post.id.replace(/\.md$/i, ''),
                title: post.data.title,
                pubDate: post.data.pubDate.toISOString(),
                description: post.data.description,
                tags,
              }}
            />
          );
        })}
      </div>
    </section>
  )}

  {posts.length === 0 && (
    <section class="animate-fade-up space-y-6 rounded-xl border border-dashed border-border/40 p-16 text-center">
      <div class="space-y-3 text-muted-foreground">
        <p class="text-sm">还没有文章</p>
        <p class="text-xs">前往 <a href="https://app.pagescms.org" target="_blank" class="text-primary hover:underline">app.pagescms.org</a> 开始编辑</p>
      </div>
    </section>
  )}
</Layout>
