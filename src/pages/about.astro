---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const about = pages.find((p) => p.id === 'about.md' || p.id === 'about');
let Content;
if (about) {
  const result = await render(about);
  Content = result.Content;
}
const title = about?.data?.title ?? '关于';
const desc = about?.data?.description;
---

<Layout title={title} description={desc || '关于'}>
  <article class="mx-auto max-w-3xl">
    <h1 class="text-3xl font-bold tracking-tight mb-6">{title}</h1>
    {desc && <p class="text-muted-foreground text-sm mb-6">{desc}</p>}

    {about && Content ? (
      <div class="prose">
        <Content />
      </div>
    ) : (
      <div class="border border-dashed border-border/40 rounded-xl p-16 text-center text-sm text-muted-foreground">
        页面内容编辑中… 去 app.pagescms.org 添加
      </div>
    )}
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.3rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose :global(h3) { font-size: 1.1rem; font-weight: 600; margin-top: 1.75rem; margin-bottom: 0.5rem; }
  .prose :global(p) { margin-bottom: 1rem; line-height: 1.8; font-size: 0.95rem; }
  .prose :global(ul) { padding-left: 1.5rem; margin-bottom: 1rem; }
  .prose :global(li) { margin-bottom: 0.25rem; line-height: 1.75; font-size: 0.95rem; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(code) {
    background: var(--color-muted);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.85em;
  }
  .prose :global(a) { text-decoration: underline; text-underline-offset: 2px; }
</style>
