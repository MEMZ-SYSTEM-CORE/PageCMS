---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const about = pages.find((p) => p.id === 'about.md' || p.id === 'about');
let Content;
if (about) {
  const result = await render(about);
  Content = result.Content;
}
const title = about?.data?.title ?? '关于';
const desc = about?.data?.description;
const pageCount = pages.length;
const postCount = (await getCollection('posts', ({ data }) => !data.draft)).length;
---

<Layout title={title} description={desc || '关于'}>
  <article class="animate-fade-up max-w-3xl">
    <div class="mb-8 space-y-3">
      <h1 class="text-4xl font-bold">{title}</h1>
      {desc && <p class="text-sm text-muted-foreground">{desc}</p>}
    </div>

    {about && Content ? (
      <div class="prose">
        <Content />
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-border/40 p-16 text-center text-sm text-muted-foreground">
        页面内容编辑中…
      </div>
    )}

    <div class="mt-16 border-t pt-6">
      <div class="flex flex-col gap-2 text-sm text-muted-foreground">
        <div>文章总数：{postCount}</div>
        <div>页面总数：{pageCount}</div>
        <div>框架：Astro</div>
        <div>内容管理：PagesCMS</div>
      </div>
      <div class="mt-6">
        <a
          href="https://space.bilibili.com/3494379408853453"
          target="_blank"
          class="inline-flex items-center gap-1.5 text-sm hover:text-foreground transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="!size-4"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.92.453.267.302.4.622.4.96 0 .338-.133.658-.4.96l-1.147 1.12v-.16zm-8.546 5.707a.7.7 0 0 0-.693.693v4.267c0 .373.32.693.693.693.373 0 .693-.32.693-.693v-4.267a.7.7 0 0 0-.693-.693zm5.333 0a.7.7 0 0 0-.693.693v4.267c0 .373.32.693.693.693.373 0 .693-.32.693-.693v-4.267a.7.7 0 0 0-.693-.693z"/></svg>
          B站主页
        </a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose :global(h3) { font-size: 1.1rem; font-weight: 600; margin-top: 1.75rem; margin-bottom: 0.5rem; }
  .prose :global(p) { margin-bottom: 1rem; line-height: 1.8; font-size: 0.95rem; }
  .prose :global(ul) { padding-left: 1.5rem; margin-bottom: 1rem; }
  .prose :global(li) { margin-bottom: 0.25rem; line-height: 1.75; font-size: 0.95rem; }
  .prose :global(strong) { font-weight: 600; }
</style>
