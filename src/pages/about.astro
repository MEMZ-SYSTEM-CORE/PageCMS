---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const about = pages.find((p) => p.id === 'about.md' || p.id === 'about');
let Content;
if (about) {
  const result = await render(about);
  Content = result.Content;
}
---

<Layout title="关于" description="关于本站">
  <article class="mx-auto max-w-3xl">
    <div class="mb-8 space-y-2">
      <h1 class="font-heading text-foreground text-3xl font-bold tracking-tight sm:text-4xl">
        {about?.data?.title ?? '关于'}
      </h1>
      {about?.data?.description && (
        <p class="text-muted-foreground text-sm">{about.data.description}</p>
      )}
    </div>

    {about && Content ? (
      <div class="prose-about">
        <Content />
      </div>
    ) : (
      <div class="border-border/40 space-y-4 rounded-xl border border-dashed p-12 text-center">
        <div class="text-muted-foreground space-y-2">
          <p class="text-sm">页面内容正在编辑中…</p>
          <p class="text-xs">
            前往 <a href="https://app.pagescms.org" target="_blank" class="text-primary hover:underline">app.pagescms.org</a>
            {' '}添加内容吧！
          </p>
        </div>
      </div>
    )}
  </article>
</Layout>

<style>
  .prose-about :global(h2) {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-foreground);
  }
  .prose-about :global(h3) {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--color-foreground);
  }
  .prose-about :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    font-size: 0.95rem;
  }
  .prose-about :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-about :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-about :global(li) {
    margin-bottom: 0.35rem;
    line-height: 1.75;
    font-size: 0.95rem;
  }
  .prose-about :global(code) {
    background: var(--color-muted);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .prose-about :global(strong) {
    font-weight: 600;
  }
</style>
